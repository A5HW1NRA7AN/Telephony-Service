# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=lead_db
POSTGRES_USER=lead_user
POSTGRES_PASSWORD=lead_password

# ── Lead Filtering ──────────────────────────────────────────────────────────
LEAD_CONTEXT=public

# ── Lead Dispatch (FreeSWITCH) ──────────────────────────────────────────────
LEAD_REGISTRY_URL=http://your-load-balancer-url.amazonaws.com/leads/v1/initiate
LEAD_REGISTRY_API_KEY_HEADER=
LEAD_REGISTRY_API_KEY_VALUE=

# ── pgAdmin ────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ── FreeSWITCH IP Configuration ─────────────────────────────────────────────
# The public IP of the Nginx / SIP Proxy gateway
EXTERNAL_IP=18.176.226.249
